ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
# Optional: required only when using openrouter/<model-slug> models.
OPENROUTER_API_KEY=

# LiteLLM model string examples:
# Anthropic: anthropic/claude-sonnet-4-6
# Groq: groq/llama-3.3-70b-versatile
# Gemini: gemini/gemini-2.5-flash
# OpenRouter: openrouter/<model-slug>
CHHAL_MODEL=anthropic/claude-sonnet-4-6
CHHAL_JUDGE_MODEL=anthropic/claude-opus-4-1

BASE_URL=http://localhost:5173
CHHAL_EPISODE_TIMEOUT_S=180
CHHAL_PROVIDER_TIMEOUT_S=60
CHHAL_ACTION_TIMEOUT_S=10
CHHAL_MAX_STEPS=20
CHHAL_DEMO_MAX_STEPS=6
CHHAL_GROQ_DELAY_S=8          # seconds between computeruse episodes on groq
CHHAL_GROQ_DELAY_S_BROWSERUSE=25  # seconds between browseruse episodes on groq
CHHAL_RATE_LIMIT_RETRIES=3    # max retries on RateLimitError before crash row

INPUT_PRICE_PER_MILLION_TOKENS_USD=3.00
OUTPUT_PRICE_PER_MILLION_TOKENS_USD=15.00
CHHAL_PRICE_IN=3.00
CHHAL_PRICE_OUT=15.00

POSTGRES_USER=armavour
POSTGRES_PASSWORD=armavour
POSTGRES_DB=armavour
POSTGRES_PORT=5432
ADMINER_PORT=8080
DATABASE_URL=postgresql+psycopg://armavour:armavour@localhost:5432/armavour
